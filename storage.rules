rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // イラスト画像: 読み取りのみ許可、書き込みはAdmin SDK（サーバーサイド）のみ
    match /illustrations/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // 共有用画像: 読み取りのみ許可、書き込みはAdmin SDK（サーバーサイド）のみ
    match /shared/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // ストーリー画像: 読み書き許可（クライアントSDKからアップロード可能）
    // サイズ制限: 5MB以下、画像ファイルのみ
    match /stories/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // その他のパスは全てブロック
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
